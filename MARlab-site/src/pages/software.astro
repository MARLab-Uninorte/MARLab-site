---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageIntro from "../components/PageIntro.astro";
import SoftwareCard from "../components/SoftwareCard.astro";
import EmptyState from "../components/EmptyState.astro";
import { getCollection } from "astro:content";

const software = await getCollection("software");
---

<BaseLayout title="Open Source Software" description="Open source tools and repositories from the Laboratorio de Mecatrónica y Robótica Aplicada.">
  <PageIntro
    eyebrow="Open Source Software"
    title="Tools we build and share"
    intro="Code released by the lab -- control libraries, simulation tools, and utilities developed alongside our research."
  />

  <section class="mx-auto max-w-6xl px-6 py-16 md:py-20">
    {software.length === 0 ? (
      <EmptyState
        message="No public repositories listed yet."
        detail="Entries are added as YAML files under src/content/software/."
      />
    ) : (
      <div class="grid gap-5 md:grid-cols-2">
        {software.map((s) => (
          <SoftwareCard name={s.data.name} description={s.data.description} repoUrl={s.data.repoUrl} tags={s.data.tags} />
        ))}
      </div>
    )}
  </section>
</BaseLayout>
