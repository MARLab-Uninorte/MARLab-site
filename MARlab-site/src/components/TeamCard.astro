---
interface Props {
  name: string;
  role: string;
  bio: string;
  isPI?: boolean;
  placeholder?: boolean;
}
const { name, role, bio, isPI = false, placeholder = false } = Astro.props;

const initials = name
  .split(" ")
  .filter((w) => w.length > 1)
  .slice(0, 2)
  .map((w) => w[0])
  .join("")
  .toUpperCase();
---

<div
  class:list={[
    "flex flex-col border p-6",
    placeholder
      ? "border-dashed border-[var(--color-ink-faint)] bg-transparent"
      : "border-[var(--color-line)] bg-[var(--color-paper)]",
  ]}
>
  <div
    class:list={[
      "flex h-16 w-16 items-center justify-center rounded-full font-display text-lg",
      placeholder
        ? "border border-dashed border-[var(--color-ink-faint)] text-[var(--color-ink-faint)]"
        : "bg-[var(--color-accent-soft)] text-[var(--color-accent-ink)]",
    ]}
    aria-hidden="true"
  >
    {placeholder ? "?" : initials}
  </div>

  <h3 class="mt-4 font-display text-lg font-medium text-[var(--color-ink)]">{name}</h3>
  <p class="eyebrow mt-1">{isPI ? "Principal Investigator" : role}</p>
  <p class="mt-3 text-sm leading-relaxed text-[var(--color-ink-soft)]">{bio}</p>
</div>
