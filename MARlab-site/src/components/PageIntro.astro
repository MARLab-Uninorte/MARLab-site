---
interface Props {
  eyebrow: string;
  title: string;
  intro?: string;
}
const { eyebrow, title, intro } = Astro.props;
---

<div class="border-b border-[var(--color-line)] bg-[var(--color-paper-dim)]">
  <div class="mx-auto max-w-6xl px-6 py-16 md:py-20">
    <p class="eyebrow">{eyebrow}</p>
    <h1 class="mt-3 max-w-2xl font-display text-4xl font-medium leading-tight text-[var(--color-ink)] md:text-5xl">
      {title}
    </h1>
    {intro && <p class="mt-5 max-w-xl text-[1.05rem] leading-relaxed text-[var(--color-ink-soft)]">{intro}</p>}
  </div>
</div>
