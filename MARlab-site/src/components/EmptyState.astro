---
interface Props {
  message: string;
  detail?: string;
}
const { message, detail } = Astro.props;
---

<div class="flex flex-col items-start gap-2 border border-dashed border-[var(--color-ink-faint)] px-6 py-10">
  <p class="font-display text-lg text-[var(--color-ink)]">{message}</p>
  {detail && <p class="max-w-md text-sm text-[var(--color-ink-soft)]">{detail}</p>}
</div>
