---
interface Props {
  tag: string;
  title: string;
  text: string;
  index: number;
  href?: string;
}
const { tag, title, text, index, href } = Astro.props;
const Tag = href ? "a" : "div";
---

<Tag
  href={href}
  class:list={[
    "group relative flex flex-col border border-[var(--color-line)] bg-[var(--color-paper)] p-7 no-underline transition-colors",
    href && "hover:border-[var(--color-accent)]",
  ]}
>
  <div class="flex items-center gap-2">
    <span class="font-mono text-[0.7rem] tracking-wide text-[var(--color-accent-ink)]">{tag}</span>
    <span class="h-px flex-1 bg-[var(--color-line)]"></span>
    <span class="font-mono text-[0.7rem] text-[var(--color-ink-faint)]">{String(index).padStart(2, "0")}</span>
  </div>
  <h3 class="mt-4 font-display text-xl font-medium text-[var(--color-ink)]">{title}</h3>
  <p class="mt-3 flex-1 text-sm leading-relaxed text-[var(--color-ink-soft)]">{text}</p>
</Tag>
