---
import LogoSlot from "./LogoSlot.astro";
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-line)] bg-[var(--color-paper-dim)]">
  <div class="mx-auto grid max-w-6xl gap-10 px-6 py-14 md:grid-cols-3">
    <div>
      <div class="flex items-center gap-3">
        <LogoSlot initials="LMRA" alt="Lab logo" />
        <LogoSlot initials="UN" alt="Universidad del Norte logo" />
      </div>
      <p class="mt-4 font-display text-lg leading-snug text-[var(--color-ink)]">
        Laboratorio de Mecatrónica<br />y Robótica Aplicada
      </p>
      <p class="mt-2 text-sm text-[var(--color-ink-soft)]">Universidad del Norte<br />Barranquilla, Colombia</p>
    </div>

    <div>
      <p class="eyebrow">Sections</p>
      <ul class="mt-3 space-y-2 text-sm text-[var(--color-ink-soft)]">
        <li><a class="hover:text-[var(--color-accent-ink)]" href={`${base}about/`}>About &amp; Mission</a></li>
        <li><a class="hover:text-[var(--color-accent-ink)]" href={`${base}research/`}>Research Areas</a></li>
        <li><a class="hover:text-[var(--color-accent-ink)]" href={`${base}people/`}>People</a></li>
        <li><a class="hover:text-[var(--color-accent-ink)]" href={`${base}publications/`}>Publications</a></li>
        <li><a class="hover:text-[var(--color-accent-ink)]" href={`${base}software/`}>Open Source Software</a></li>
      </ul>
    </div>

    <div>
      <p class="eyebrow">Contact</p>
      <ul class="mt-3 space-y-2 text-sm text-[var(--color-ink-soft)]">
        <li><a class="hover:text-[var(--color-accent-ink)]" href="mailto:lmra@uninorte.edu.co">lmra@uninorte.edu.co</a></li>
        <li>Km 5 Vía Puerto Colombia</li>
        <li>Barranquilla, Atlántico, Colombia</li>
      </ul>
    </div>
  </div>

  <div class="border-t border-[var(--color-line)] px-6 py-5">
    <p class="mx-auto max-w-6xl font-mono text-[0.7rem] uppercase tracking-wide text-[var(--color-ink-faint)]">
      © {year} Laboratorio de Mecatrónica y Robótica Aplicada, Universidad del Norte
    </p>
  </div>
</footer>
