---
// Signature element: a schematic kinematic-chain diagram (links + revolute joints),
// evoking a robotic arm blueprint. Reused at different scales across the site.
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<svg
  viewBox="0 0 520 420"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
>
  <!-- base -->
  <rect x="40" y="360" width="90" height="14" rx="2" stroke="var(--color-ink-faint)" stroke-width="1.5"/>
  <line x1="85" y1="360" x2="85" y2="300" stroke="var(--color-ink-faint)" stroke-width="1.5"/>

  <!-- link 1 -->
  <line x1="85" y1="300" x2="220" y2="240" stroke="var(--color-accent)" stroke-width="2"/>
  <!-- link 2 -->
  <line x1="220" y1="240" x2="255" y2="120" stroke="var(--color-accent)" stroke-width="2"/>
  <!-- link 3 -->
  <line x1="255" y1="120" x2="400" y2="90" stroke="var(--color-accent)" stroke-width="2"/>
  <!-- end effector -->
  <line x1="400" y1="90" x2="460" y2="130" stroke="var(--color-ink-soft)" stroke-width="1.5"/>
  <line x1="400" y1="90" x2="450" y2="60" stroke="var(--color-ink-soft)" stroke-width="1.5"/>

  <!-- joints -->
  <circle cx="85" cy="300" r="7" fill="var(--color-paper)" stroke="var(--color-accent-ink)" stroke-width="2"/>
  <circle cx="220" cy="240" r="7" fill="var(--color-paper)" stroke="var(--color-accent-ink)" stroke-width="2"/>
  <circle cx="255" cy="120" r="7" fill="var(--color-paper)" stroke="var(--color-accent-ink)" stroke-width="2"/>
  <circle cx="400" cy="90" r="6" fill="var(--color-accent)" stroke="var(--color-accent-ink)" stroke-width="1.5"/>

  <!-- dimension / trace lines, decorative -->
  <path d="M40 40 L40 20 L150 20" stroke="var(--color-line)" stroke-width="1" stroke-dasharray="3 4"/>
  <path d="M480 380 L500 380 L500 200" stroke="var(--color-line)" stroke-width="1" stroke-dasharray="3 4"/>
  <circle cx="150" cy="20" r="2" fill="var(--color-line)"/>
  <circle cx="500" cy="200" r="2" fill="var(--color-line)"/>
</svg>
