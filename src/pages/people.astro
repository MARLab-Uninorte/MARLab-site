---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageIntro from "../components/PageIntro.astro";
import TeamCard from "../components/TeamCard.astro";
import { getCollection } from "astro:content";

const team = (await getCollection("team")).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="People" description="Meet the team of the Laboratorio de Mecatrónica y Robótica Aplicada.">
  <PageIntro
    eyebrow="People"
    title="The team"
    intro="Led by the Principal Investigator, with open seats for the students and collaborators joining the lab."
  />

  <section class="mx-auto max-w-6xl px-6 py-16 md:py-20">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {team.map((member) => (
        <TeamCard
          name={member.data.name}
          role={member.data.role}
          bio={member.data.bio}
          isPI={member.data.isPI}
          placeholder={member.data.placeholder}
        />
      ))}
    </div>
  </section>
</BaseLayout>
