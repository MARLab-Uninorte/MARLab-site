---
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Page not found">
  <section class="mx-auto flex max-w-6xl flex-col items-start px-6 py-28">
    <p class="eyebrow">404</p>
    <h1 class="mt-3 font-display text-4xl font-medium text-[var(--color-ink)]">Page not found</h1>
    <p class="mt-4 max-w-md text-[var(--color-ink-soft)]">
      The page you're looking for doesn't exist or has moved.
    </p>
    <a href={base} class="mt-8 border border-[var(--color-ink)] px-5 py-2.5 font-mono text-xs uppercase tracking-wide text-[var(--color-ink)] transition-colors hover:bg-[var(--color-ink)] hover:text-[var(--color-paper)]">
      Back to home
    </a>
  </section>
</BaseLayout>
