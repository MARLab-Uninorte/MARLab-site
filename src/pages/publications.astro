---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageIntro from "../components/PageIntro.astro";
import PublicationRow from "../components/PublicationRow.astro";
import EmptyState from "../components/EmptyState.astro";
import { getCollection } from "astro:content";

const publications = (await getCollection("publications")).sort((a, b) => b.data.year - a.data.year);
---

<BaseLayout title="Publications" description="Publications from the Laboratorio de Mecatrónica y Robótica Aplicada.">
  <PageIntro
    eyebrow="Publications"
    title="Papers & reports"
    intro="Journal articles, conference papers, and technical reports produced by the lab."
  />

  <section class="mx-auto max-w-3xl px-6 py-16 md:py-20">
    {publications.length === 0 ? (
      <EmptyState
        message="No publications listed yet."
        detail="Entries are added as YAML files under src/content/publications/."
      />
    ) : (
      <div class="flex flex-col">
        {publications.map((p) => (
          <PublicationRow title={p.data.title} authors={p.data.authors} venue={p.data.venue} year={p.data.year} link={p.data.link} tags={p.data.tags} />
        ))}
      </div>
    )}
  </section>
</BaseLayout>
